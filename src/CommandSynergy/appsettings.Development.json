{
  "CardMetadata": {
    "SnapshotDirectory": "Data/CardMetadata",
    "SnapshotFileName": "cards.parquet",
    "SearchIndexVersion": "v1-dev"
  },
  "Bracket": {
    "MinimumBracketLevel": 1,
    "MaximumBracketLevel": 5,
    "LevelThresholds": [ 0, 5, 10, 15, 20 ]
  },
  "Scryfall": {
    "BaseUrl": "https://api.scryfall.com/",
    "UserAgent": "CommandSynergy/0.1-dev"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
