@using System.Text

<script type="module" src="@Assets["Components/Cards/CommanderCard.razor.js"]"></script>

<article class="commander-card @(IsCompact ? "commander-card--compact" : string.Empty)" data-testid="commander-card-@Card.CardId">
    <div class="commander-card__surface @(Card.HasMultipleFaces ? "commander-card__surface--multi-face" : string.Empty)"
         id="@surfaceId"
         data-testid="card-surface-@Card.CardId">
        <section class="commander-card__face commander-card__face--front">
            <div class="commander-card__art">
                @if (TryGetImageUri(frontFace, out var frontImageUri))
                {
                    <img class="commander-card__art-image"
                         src="@frontImageUri"
                         alt="@($"{frontFace.Name} artwork")"
                         loading="lazy" />
                }
                else
                {
                    <div class="commander-card__art-placeholder" aria-hidden="true"></div>
                }
            </div>
            <div class="commander-card__content">
                <div class="commander-card__topline">
                    <h3>@frontFace.Name</h3>
                    @if (!string.IsNullOrWhiteSpace(frontFace.ManaCost ?? Card.ManaCost))
                    {
                        <span>@(frontFace.ManaCost ?? Card.ManaCost)</span>
                    }
                </div>
                <p>@frontFace.TypeLine</p>
            </div>
        </section>

        @if (backFace is not null)
        {
            <section class="commander-card__face commander-card__face--back">
                <div class="commander-card__art">
                    @if (TryGetImageUri(backFace, out var backImageUri))
                    {
                        <img class="commander-card__art-image"
                             src="@backImageUri"
                             alt="@($"{backFace.Name} artwork")"
                             loading="lazy" />
                    }
                    else
                    {
                        <div class="commander-card__art-placeholder" aria-hidden="true"></div>
                    }
                </div>
                <div class="commander-card__content">
                    <div class="commander-card__topline">
                        <h3>@backFace.Name</h3>
                        @if (!string.IsNullOrWhiteSpace(backFace.ManaCost))
                        {
                            <span>@backFace.ManaCost</span>
                        }
                    </div>
                    <p>@backFace.TypeLine</p>
                </div>
            </section>
        }
    </div>

    <footer class="commander-card__footer">
        <div class="commander-card__meta">
            @if (Card.IsCommander)
            {
                <span class="commander-card__tag commander-card__tag--commander">Commander</span>
            }
            <span class="commander-card__tag">@Card.Quantity x</span>
            @if (Card.ColorIdentity.Count > 0)
            {
                <span class="commander-card__identity" aria-label="Color identity">
                    @foreach (var color in Card.ColorIdentity)
                    {
                        <span class="commander-card__pip commander-card__pip--@ResolveColorClass(color)"
                              title="@ResolveColorName(color)"></span>
                    }
                </span>
            }
        </div>

        <div class="commander-card__actions">
            @if (Card.SaltScore is not null)
            {
                <span class="commander-card__salt" data-testid="salt-badge-@Card.CardId">Salt @Card.SaltScore.Value.ToString("0.#")</span>
            }

            @if (backFace is not null)
            {
                <button type="button"
                        class="commander-card__flip-button"
                        data-face-toggle-target="@surfaceId"
                        data-testid="face-toggle-@Card.CardId">
                    Flip face
                </button>
            }
        </div>
    </footer>
</article>

@code {
    [Parameter]
    public required WorkspaceCardView Card { get; set; }

    [Parameter]
    public bool IsCompact { get; set; }

    private WorkspaceCardFaceView frontFace => Card.Faces.First(static face => face.IsPrimaryFace);

    private WorkspaceCardFaceView? backFace => Card.Faces.FirstOrDefault(static face => !face.IsPrimaryFace);

    private string surfaceId => $"commander-card-{Convert.ToHexString(Encoding.UTF8.GetBytes(Card.CardId))}";

    private bool TryGetImageUri(WorkspaceCardFaceView face, out string imageUri)
    {
        var resolvedImageUri = face.ImageUri ?? Card.ImageUri;
        if (string.IsNullOrWhiteSpace(resolvedImageUri))
        {
            imageUri = string.Empty;
            return false;
        }

        imageUri = resolvedImageUri;
        return true;
    }

    private static string ResolveColorClass(string color) => color.Trim().ToUpperInvariant() switch
    {
        "W" => "white",
        "U" => "blue",
        "B" => "black",
        "R" => "red",
        "G" => "green",
        _ => "colorless",
    };

    private static string ResolveColorName(string color) => color.Trim().ToUpperInvariant() switch
    {
        "W" => "White",
        "U" => "Blue",
        "B" => "Black",
        "R" => "Red",
        "G" => "Green",
        _ => "Colorless",
    };
}