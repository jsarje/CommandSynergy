@inherits LayoutComponentBase

<MudThemeProvider Theme="workspaceTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="app-shell">
    @Body
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private readonly MudTheme workspaceTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1f5b4b",
            Secondary = "#8d6a2f",
            Tertiary = "#8b3f29",
            Background = "#f2ecdf",
            Surface = "#fbf7ef",
            TextPrimary = "#14261f",
            TextSecondary = "#5d685f",
            Info = "#2e6c78",
            Success = "#2d6a45",
            Warning = "#a77721",
            Error = "#8b3f29",
            AppbarBackground = "#fbf7ef",
            AppbarText = "#14261f",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Public Sans", "Trebuchet MS", "sans-serif"],
            },
            H1 = new H1Typography
            {
                FontFamily = ["Cormorant Garamond", "Georgia", "serif"],
            },
            H2 = new H2Typography
            {
                FontFamily = ["Cormorant Garamond", "Georgia", "serif"],
            },
            H3 = new H3Typography
            {
                FontFamily = ["Cormorant Garamond", "Georgia", "serif"],
            },
            H4 = new H4Typography
            {
                FontFamily = ["Cormorant Garamond", "Georgia", "serif"],
            },
            H5 = new H5Typography
            {
                FontFamily = ["Cormorant Garamond", "Georgia", "serif"],
            },
            H6 = new H6Typography
            {
                FontFamily = ["Cormorant Garamond", "Georgia", "serif"],
            },
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "22px",
        },
    };
}
