@inherits LayoutComponentBase

<MudThemeProvider Theme="workspaceTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="app-shell">
    @Body
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private readonly MudTheme workspaceTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#355847",
            Secondary = "#8a6a32",
            Tertiary = "#8f4c34",
            Background = "#f2ece1",
            Surface = "#fbf6ee",
            TextPrimary = "#203128",
            TextSecondary = "#677066",
            Info = "#406c73",
            Success = "#426a4f",
            Warning = "#98712d",
            Error = "#8f4c34",
            AppbarBackground = "#fbf6ee",
            AppbarText = "#203128",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Familjen Grotesk", "Segoe UI", "sans-serif"],
            },
            H1 = new H1Typography
            {
                FontFamily = ["Literata", "Georgia", "serif"],
            },
            H2 = new H2Typography
            {
                FontFamily = ["Literata", "Georgia", "serif"],
            },
            H3 = new H3Typography
            {
                FontFamily = ["Literata", "Georgia", "serif"],
            },
            H4 = new H4Typography
            {
                FontFamily = ["Literata", "Georgia", "serif"],
            },
            H5 = new H5Typography
            {
                FontFamily = ["Literata", "Georgia", "serif"],
            },
            H6 = new H6Typography
            {
                FontFamily = ["Literata", "Georgia", "serif"],
            },
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "22px",
        },
    };
}
