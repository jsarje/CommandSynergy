@page "/Error"
@using System.Diagnostics
@layout MainLayout

<PageTitle>Something went wrong — Synergy Sphere</PageTitle>

<div class="error-page">
    <p class="error-page__eyebrow">Error</p>
    <h1>Something went wrong.</h1>
    <p>An unexpected error occurred while processing your request. The issue has been logged.</p>

    @if (ShowRequestId)
    {
        <p class="error-page__meta">
            <strong>Request ID:</strong> <code class="error-page__detail">@RequestId</code>
        </p>
    }

    <a href="/" class="error-page__back">← Back to workspace</a>

    <details class="error-page__dev-details">
        <summary>Developer notes</summary>
        <p>Switch to the <strong>Development</strong> environment to see detailed exception information. Do not enable this on deployed applications — it may expose sensitive data to end users.</p>
        <p>Set the <code>ASPNETCORE_ENVIRONMENT</code> environment variable to <code>Development</code> and restart the app.</p>
    </details>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
