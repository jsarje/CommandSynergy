@page "/Error"
@using System.Diagnostics
@layout MainLayout

<PageTitle>Something went wrong — Synergy Sphere</PageTitle>

<div class="error-page">
    <p class="error-page__eyebrow">Workspace interrupted</p>
    <h1>Something went wrong.</h1>
    <p>An unexpected error interrupted the workspace. Your deck data is still in the browser, but this view needs a clean reload.</p>

    @if (ShowRequestId)
    {
        <p class="error-page__meta">
            <strong>Request ID:</strong> <code class="error-page__detail">@RequestId</code>
        </p>
    }

    <a href="/" class="error-page__back">Back to workspace</a>

    <details class="error-page__dev-details">
        <summary>Developer notes</summary>
        <p>Use the <strong>Development</strong> environment for detailed exception information. Do not enable it on deployed apps.</p>
        <p>Set <code>ASPNETCORE_ENVIRONMENT</code> to <code>Development</code> and restart the app.</p>
    </details>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
