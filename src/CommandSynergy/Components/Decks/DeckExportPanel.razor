@using CommandSynergy.Application.Contracts

<div class="workspace-stack workspace-export-panel">
    <div class="workspace-panel__header">
        <div>
            <p class="workspace-panel__label">Export</p>
            <h2>Share the current list</h2>
        </div>
        <span class="workspace-panel__badge">@SelectedFormatId</span>
    </div>

    <MudSelect T="string" Label="Target format" Value="@SelectedFormatId" ValueChanged="ExportFormatChanged">
        @foreach (var option in SupportedFormats)
        {
            <MudSelectItem Value="@option.Value">@option.Label</MudSelectItem>
        }
    </MudSelect>

    <div class="workspace-search">
        <button type="button" class="workspace-search__button" @onclick="ExportRequested">Generate preview</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(ExportStatusMessage))
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@ExportStatusMessage</MudAlert>
    }

    @if (ExportPreview is null)
    {
        <p class="workspace-panel__empty">Generate a local export preview from the active workspace.</p>
    }
    else
    {
        <div class="workspace-subheader">
            <span class="workspace-subheader__label">Preview</span>
            <span class="workspace-subheader__value">@SelectedFormatId</span>
        </div>

        if (ExportPreview.Warnings.Count > 0)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                @string.Join(" ", ExportPreview.Warnings)
            </MudAlert>
        }

        <MudTextField T="string"
                      Label="Export preview"
                      Lines="12"
                      Value="@ExportPreview.DocumentText"
                      ReadOnly="true"
                      Variant="Variant.Outlined" />
    }
</div>

@code {
    [Parameter]
    public ExportPreviewContract? ExportPreview { get; set; }

    [Parameter]
    public required IReadOnlyList<FormatOptionView> SupportedFormats { get; set; }

    [Parameter]
    public required string SelectedFormatId { get; set; }

    [Parameter]
    public string? ExportStatusMessage { get; set; }

    [Parameter]
    public EventCallback<string> ExportFormatChanged { get; set; }

    [Parameter]
    public EventCallback ExportRequested { get; set; }
}