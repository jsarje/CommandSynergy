@using CommandSynergy.Application.Contracts
@using CommandSynergy.Components.Cards
@using System.Globalization

<section class="pile-board">
    <div class="pile-board__header">
        <div class="pile-board__header-copy">
            <p class="workspace-panel__label">Deck table</p>
            <h2>Command zone and mainboard</h2>
            <p class="pile-board__hint">Use grouping to read the deck by role, mana, or color. Switch to compact mode when you want a faster scan of the full 99.</p>
        </div>
    </div>

    <div class="pile-board__lanes">
        @foreach (var lane in VisibleLanes)
        {
            var cardsInPile = GetCardsForPile(lane.PileId);
            var laneClass = GetLaneClass(lane.PileId);

            <section class="pile-board__pile @laneClass"
                     data-testid="pile-lane-@lane.PileId">
                <header class="pile-board__pile-header">
                    <div>
                        <h3>@lane.Name</h3>
                        <p>@cardsInPile.Sum(static card => card.Quantity) cards</p>
                    </div>

                    @if (string.Equals(lane.PileId, DeckWorkspaceViewModel.MainboardPileId, StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="pile-board__header-side">
                            <div class="pile-board__controls" data-testid="mainboard-controls">
                                <label class="pile-board__control">
                                    <span>Group mainboard</span>
                                    <select @bind="selectedGrouping" data-testid="mainboard-grouping">
                                        <option value="@MainboardGrouping.Type">Type</option>
                                        <option value="@MainboardGrouping.ManaCost">Mana cost</option>
                                        <option value="@MainboardGrouping.Color">Color</option>
                                        <option value="@MainboardGrouping.Rarity">Rarity</option>
                                        <option value="@MainboardGrouping.Set">Set</option>
                                        <option value="@MainboardGrouping.None">No grouping</option>
                                    </select>
                                </label>

                                <label class="pile-board__control">
                                    <span>Sort cards</span>
                                    <select @bind="selectedSorting" data-testid="mainboard-sorting">
                                        <option value="@MainboardSorting.Name">Name</option>
                                        <option value="@MainboardSorting.ManaCost">Mana cost</option>
                                        <option value="@MainboardSorting.Type">Type</option>
                                        <option value="@MainboardSorting.Color">Color</option>
                                    </select>
                                </label>

                                <button type="button"
                                        class="pile-board__compact-toggle"
                                        aria-pressed="@isCompactMode"
                                        aria-label="@(isCompactMode ? "Cards are compact. Expand cards" : "Cards are expanded. Compact cards")"
                                        data-testid="compact-mode-toggle"
                                        @onclick="ToggleCompactMode">
                                    @(isCompactMode ? "Expand cards" : "Compact cards")
                                </button>
                            </div>
                        </div>
                    }
                </header>

                <div class="pile-board__cards @(IsCommandZone(lane.PileId) ? "pile-board__cards--command" : "pile-board__cards--mainboard")">
                    @if (cardsInPile.Length == 0)
                    {
                        <p class="pile-board__empty">@GetEmptyMessage(lane.PileId)</p>
                    }
                    else if (IsCommandZone(lane.PileId))
                    {
                        @foreach (var card in cardsInPile.OrderBy(static card => card.Name, StringComparer.OrdinalIgnoreCase))
                        {
                            @RenderCard(card, isMainboard: false)
                        }
                    }
                    else
                    {
                        var groups = GetMainboardGroups(cardsInPile);

                        @foreach (var group in groups)
                        {
                            <section id="@GetGroupAnchorId(group)"
                                     class="pile-board__group"
                                     data-testid="mainboard-group-@group.TestId">
                                <header class="pile-board__group-header">
                                    @if (groups.Count > 1)
                                    {
                                        <details class="pile-board__group-jump"
                                                 data-testid="mainboard-group-jump-@group.TestId">
                                            <summary class="pile-board__group-jump-summary"
                                                     data-testid="mainboard-group-current-@group.TestId">
                                                <h4>@group.Label</h4>
                                                <span class="pile-board__group-jump-affordance">Jump to</span>
                                            </summary>

                                            <nav class="pile-board__group-jump-menu"
                                                 aria-label="Jump to another mainboard section">
                                                @foreach (var targetGroup in groups)
                                                {
                                                    <a href="#@GetGroupAnchorId(targetGroup)"
                                                       class="pile-board__group-jump-link"
                                                       data-testid="mainboard-group-link-@targetGroup.TestId"
                                                       aria-current="@(targetGroup.TestId == group.TestId ? "location" : null)">
                                                        @targetGroup.Label
                                                    </a>
                                                }
                                            </nav>
                                        </details>
                                    }
                                    else
                                    {
                                        <h4>@group.Label</h4>
                                    }

                                    <span>@group.TotalQuantity cards</span>
                                </header>

                                <div class="pile-board__group-cards @(isCompactMode ? "pile-board__group-cards--compact" : string.Empty)">
                                    @foreach (var card in group.Cards)
                                    {
                                        @RenderCard(card, isMainboard: true)
                                    }
                                </div>
                            </section>
                        }
                    }
                </div>
            </section>
        }
    </div>
</section>

@code {
    [Parameter]
    public required IReadOnlyList<PileDefinitionContract> Piles { get; set; }

    [Parameter]
    public required IReadOnlyList<WorkspaceCardView> Cards { get; set; }

    [Parameter]
    public bool CommanderSelectionEnabled { get; set; }

    [Parameter]
    public EventCallback<string> SetCommanderRequested { get; set; }

    [Parameter]
    public EventCallback<string> IncrementRequested { get; set; }

    [Parameter]
    public EventCallback<string> DecrementRequested { get; set; }

    [Parameter]
    public EventCallback<string> RemoveRequested { get; set; }

    private const string UnknownRarityLabel = "Unknown rarity";
    private const string UnknownSetLabel = "Unknown set";

    private static readonly TypeGroupDefinition[] PrimaryTypeGroups =
    [
        new("Creature", "Creatures", 0),
        new("Planeswalker", "Planeswalkers", 1),
        new("Sorcery", "Sorceries", 2),
        new("Instant", "Instants", 3),
        new("Artifact", "Artifacts", 4),
        new("Enchantment", "Enchantments", 5),
        new("Land", "Lands", 6),
    ];

    private bool isCompactMode;
    private MainboardGrouping selectedGrouping = MainboardGrouping.Type;
    private MainboardSorting selectedSorting = MainboardSorting.Name;

    private IReadOnlyList<PileDefinitionContract> VisibleLanes => Piles
        .Where(static pile => string.Equals(pile.PileId, DeckWorkspaceViewModel.CommandZonePileId, StringComparison.OrdinalIgnoreCase)
            || string.Equals(pile.PileId, DeckWorkspaceViewModel.MainboardPileId, StringComparison.OrdinalIgnoreCase))
        .OrderBy(static pile => pile.SortOrder)
        .ToArray();

    private RenderFragment RenderCard(WorkspaceCardView card, bool isMainboard) => builder =>
    {
        var sequence = 0;
        var compactClass = isMainboard && isCompactMode ? " pile-board__card--compact" : string.Empty;

        builder.OpenElement(sequence++, "article");
        builder.AddAttribute(sequence++, "class", $"pile-board__card{compactClass}");
        builder.AddAttribute(sequence++, "data-testid", $"pile-card-{card.CardId}");

        builder.OpenComponent<CommanderCard>(sequence++);
        builder.AddAttribute(sequence++, "Card", card);
        builder.AddAttribute(sequence++, "IsCompact", isMainboard && isCompactMode);
        builder.CloseComponent();

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "pile-board__actions");

        if (isMainboard && !card.IsCommander && card.AllowsMultipleCopies)
        {
            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", "pile-board__quantity-button");
            builder.AddAttribute(sequence++, "data-testid", $"decrement-{card.CardId}");
            builder.AddAttribute(sequence++, "disabled", card.Quantity <= 1);
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => DecrementRequested.InvokeAsync(card.CardId)));
            builder.AddContent(sequence++, "−1");
            builder.CloseElement();

            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "pile-board__quantity");
            builder.AddAttribute(sequence++, "data-testid", $"quantity-{card.CardId}");
            builder.AddContent(sequence++, $"{card.Quantity} copies");
            builder.CloseElement();

            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", "pile-board__quantity-button");
            builder.AddAttribute(sequence++, "data-testid", $"increment-{card.CardId}");
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => IncrementRequested.InvokeAsync(card.CardId)));
            builder.AddContent(sequence++, "+1");
            builder.CloseElement();
        }

        if (CommanderSelectionEnabled && !card.IsCommander)
        {
            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", "pile-board__move-button");
            builder.AddAttribute(sequence++, "data-testid", $"set-commander-from-pile-{card.CardId}");
            builder.AddAttribute(sequence++, "disabled", !card.IsCommanderEligible);
            builder.AddAttribute(sequence++, "title", card.IsCommanderEligible ? "Set this card as your commander" : "Only legal commanders can be selected.");
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => SetCommanderRequested.InvokeAsync(card.CardId)));
            builder.AddContent(sequence++, "Set as commander");
            builder.CloseElement();
        }

        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", "pile-board__remove-button");
        builder.AddAttribute(sequence++, "data-testid", $"remove-{card.CardId}");
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => RemoveRequested.InvokeAsync(card.CardId)));
        builder.AddContent(sequence++, "Remove");
        builder.CloseElement();

        builder.CloseElement();
        builder.CloseElement();
    };

    private WorkspaceCardView[] GetCardsForPile(string pileId) => Cards
        .Where(card => string.Equals(ResolvePileId(card), pileId, StringComparison.OrdinalIgnoreCase))
        .ToArray();

    private static bool IsCommandZone(string pileId) => string.Equals(pileId, DeckWorkspaceViewModel.CommandZonePileId, StringComparison.OrdinalIgnoreCase);

    private static string GetLaneClass(string pileId) => IsCommandZone(pileId)
        ? "pile-board__pile--command"
        : "pile-board__pile--mainboard";

    private static string GetEmptyMessage(string pileId) => IsCommandZone(pileId)
        ? "Choose a legal commander to activate the command zone."
        : "Search results and imports add cards straight into the mainboard.";

    private static string ResolvePileId(WorkspaceCardView card) => card.IsCommander
        ? DeckWorkspaceViewModel.CommandZonePileId
        : card.AssignedPileId;

    private IReadOnlyList<CardGroupView> GetMainboardGroups(IReadOnlyList<WorkspaceCardView> cards)
    {
        var sortedCards = SortCards(cards);
        return sortedCards
            .GroupBy(GetEffectiveGroupKey)
            .Select(CreateGroupView)
            .OrderBy(static group => group.SortOrder)
            .ThenBy(static group => group.Label, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private WorkspaceCardView[] SortCards(IReadOnlyList<WorkspaceCardView> cards) => selectedSorting switch
    {
        MainboardSorting.ManaCost => cards
            .OrderBy(static card => card.ManaValue)
            .ThenBy(static card => card.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray(),
        MainboardSorting.Type => cards
            .OrderBy(card => GetTypeOrder(ResolveTypeGroup(card)))
            .ThenBy(static card => card.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray(),
        MainboardSorting.Color => cards
            .OrderBy(card => ResolveColorSortKey(card))
            .ThenBy(static card => card.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray(),
        _ => cards
            .OrderBy(static card => card.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray(),
    };

    private string GetGroupKey(WorkspaceCardView card) => selectedGrouping switch
    {
        MainboardGrouping.ManaCost => $"mana:{card.ManaValue:0.##}",
        MainboardGrouping.Color => $"color:{ResolveColorGroup(card)}",
        MainboardGrouping.Rarity => $"rarity:{ResolveRarityGroup(card)}",
        MainboardGrouping.Set => $"set:{ResolveSetGroup(card)}",
        _ => $"type:{ResolveTypeGroup(card)}",
    };

    private string GetNavigationGroupKey(WorkspaceCardView card) => selectedSorting switch
    {
        MainboardSorting.ManaCost => $"mana:{card.ManaValue:0.##}",
        MainboardSorting.Type => $"type:{ResolveTypeGroup(card)}",
        MainboardSorting.Color => $"color:{ResolveColorGroup(card)}",
        _ => $"name:{ResolveNameGroup(card)}",
    };

    private string GetEffectiveGroupKey(WorkspaceCardView card) => selectedGrouping is MainboardGrouping.None
        ? GetNavigationGroupKey(card)
        : GetGroupKey(card);

    private void ToggleCompactMode()
    {
        isCompactMode = !isCompactMode;
    }

    private static string ResolveTypeGroup(WorkspaceCardView card)
    {
        return PrimaryTypeGroups.FirstOrDefault(type => card.TypeLine.Contains(type.MatchText, StringComparison.OrdinalIgnoreCase))?.Label
            ?? "Other";
    }

    private static int GetTypeOrder(string typeGroup) => typeGroup switch
    {
        _ => PrimaryTypeGroups.FirstOrDefault(type => string.Equals(type.Label, typeGroup, StringComparison.OrdinalIgnoreCase))?.SortOrder ?? int.MaxValue,
    };

    private static string ResolveColorGroup(WorkspaceCardView card)
    {
        if (card.ColorIdentity.Count == 0)
        {
            return "Colorless";
        }

        if (card.ColorIdentity.Count == 1)
        {
            return ResolveColorName(card.ColorIdentity[0]);
        }

        var orderedColors = card.ColorIdentity
            .Select(ResolveColorName)
            .OrderBy(ResolveColorOrder)
            .ToArray();

        return $"Multicolor — {string.Join(" / ", orderedColors)}";
    }

    private static int ResolveColorSortKey(WorkspaceCardView card)
    {
        if (card.ColorIdentity.Count == 0)
        {
            return 0;
        }

        if (card.ColorIdentity.Count > 1)
        {
            return 100 + card.ColorIdentity.Count;
        }

        return ResolveColorOrder(ResolveColorName(card.ColorIdentity[0]));
    }

    private static int ResolveColorOrder(string color) => color switch
    {
        "Colorless" => 0,
        "White" => 1,
        "Blue" => 2,
        "Black" => 3,
        "Red" => 4,
        "Green" => 5,
        _ when color.StartsWith("Multicolor", StringComparison.OrdinalIgnoreCase) => 6,
        _ => 7,
    };

    private static string ResolveColorName(string color) => color.Trim().ToUpperInvariant() switch
    {
        "W" => "White",
        "U" => "Blue",
        "B" => "Black",
        "R" => "Red",
        "G" => "Green",
        _ => "Colorless",
    };

    private static string ResolveRarityGroup(WorkspaceCardView card)
    {
        if (!string.IsNullOrWhiteSpace(card.SourceTag))
        {
            var normalizedTag = card.SourceTag.Trim();
            if (normalizedTag.Equals("common", StringComparison.OrdinalIgnoreCase)
                || normalizedTag.Equals("uncommon", StringComparison.OrdinalIgnoreCase)
                || normalizedTag.Equals("rare", StringComparison.OrdinalIgnoreCase)
                || normalizedTag.Equals("mythic", StringComparison.OrdinalIgnoreCase)
                || normalizedTag.Equals("mythic rare", StringComparison.OrdinalIgnoreCase))
            {
                return normalizedTag.Equals("mythic rare", StringComparison.OrdinalIgnoreCase)
                    ? "Mythic"
                    : char.ToUpperInvariant(normalizedTag[0]) + normalizedTag[1..].ToLowerInvariant();
            }
        }

        return UnknownRarityLabel;
    }

    private static int ResolveRarityOrder(string rarity) => rarity switch
    {
        "Common" => 0,
        "Uncommon" => 1,
        "Rare" => 2,
        "Mythic" => 3,
        _ => 4,
    };

    private static string ResolveSetGroup(WorkspaceCardView card) => string.IsNullOrWhiteSpace(card.SourceSetCode)
        ? UnknownSetLabel
        : $"Set {card.SourceSetCode.Trim().ToUpperInvariant()}";

    private static string ResolveNameGroup(WorkspaceCardView card)
    {
        var trimmedName = card.Name.Trim();
        if (trimmedName.Length == 0)
        {
            return "#";
        }

        var firstCharacter = trimmedName[0];
        return char.IsLetter(firstCharacter)
            ? char.ToUpperInvariant(firstCharacter).ToString()
            : "#";
    }

    // Extract the numeric mana-value suffix for deterministic group ordering from either raw
    // numeric group values (derived navigation) or formatted labels such as "Mana value 3".
    private static decimal ParseGroupOrder(string label)
    {
        if (decimal.TryParse(label, NumberStyles.Number, CultureInfo.InvariantCulture, out var parsedValue))
        {
            return parsedValue;
        }

        var lastSpaceIndex = label.LastIndexOf(' ');
        return lastSpaceIndex > -1 && decimal.TryParse(label[(lastSpaceIndex + 1)..], NumberStyles.Number, CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : 0m;
    }

    private static string ToTestId(string label)
    {
        return new string(label
            .Trim()
            .ToLowerInvariant()
            .Select(character => char.IsLetterOrDigit(character) ? character : '-')
            .ToArray())
            .Trim('-');
    }

    private static string GetGroupAnchorId(CardGroupView group) => $"mainboard-section-{group.TestId}";

    private static CardGroupView CreateGroupView(IGrouping<string, WorkspaceCardView> group)
    {
        var separatorIndex = group.Key.IndexOf(':');
        var value = group.Key[(separatorIndex + 1)..];
        var (label, sortOrder) = group.Key[..separatorIndex] switch
        {
            "mana" => ($"Mana value {value}", ParseGroupOrder(value)),
            "color" => (value, ResolveColorOrder(value)),
            "rarity" => (value, ResolveRarityOrder(value)),
            "set" => (value, string.Equals(value, UnknownSetLabel, StringComparison.OrdinalIgnoreCase) ? int.MaxValue : 0),
            "name" => (value, string.Equals(value, "#", StringComparison.Ordinal) ? -1 : 0),
            _ => (value, GetTypeOrder(value)),
        };

        return new CardGroupView(label, ToTestId(group.Key), group.ToArray(), sortOrder);
    }

    private sealed record CardGroupView(string Label, string TestId, IReadOnlyList<WorkspaceCardView> Cards, decimal SortOrder)
    {
        public int TotalQuantity => Cards.Sum(static card => card.Quantity);
    }

    private sealed record TypeGroupDefinition(string MatchText, string Label, int SortOrder);

    private enum MainboardGrouping
    {
        Type,
        ManaCost,
        Color,
        Rarity,
        Set,
        None,
    }

    private enum MainboardSorting
    {
        Name,
        ManaCost,
        Type,
        Color,
    }
}
