@using CommandSynergy.Application.Contracts

<section class="pile-board">
    <div class="pile-board__header">
        <div>
            <p class="workspace-panel__label">Workspace</p>
            <h2>Two lanes, one clear deckbench</h2>
        </div>
        <p class="pile-board__hint">The command zone stays compact while the mainboard gets the space needed for the other 98-plus cards.</p>
    </div>

    <div class="pile-board__lanes">
        @foreach (var lane in VisibleLanes)
        {
            var cardsInPile = GetCardsForPile(lane.PileId);
            var laneClass = GetLaneClass(lane.PileId);

            <section class="pile-board__pile @laneClass"
                     data-testid="pile-lane-@lane.PileId">
                <header class="pile-board__pile-header">
                    <div>
                        <h3>@lane.Name</h3>
                        <p>@cardsInPile.Sum(static card => card.Quantity) cards</p>
                    </div>
                    <span class="pile-board__lane-badge">@GetLaneBadge(lane.PileId)</span>
                </header>

                <p class="pile-board__pile-note">@GetLaneDescription(lane.PileId)</p>

                <div class="pile-board__cards @(IsCommandZone(lane.PileId) ? "pile-board__cards--command" : "pile-board__cards--mainboard")">
                    @if (cardsInPile.Length == 0)
                    {
                        <p class="pile-board__empty">@GetEmptyMessage(lane.PileId)</p>
                    }
                    else
                    {
                        @foreach (var card in cardsInPile)
                        {
                            <article class="pile-board__card"
                                     data-testid="pile-card-@card.CardId">
                                <CommanderCard Card="card" />

                                <div class="pile-board__actions">
                                    @if (CommanderSelectionEnabled && !card.IsCommander)
                                    {
                                        <button type="button"
                                                class="pile-board__move-button"
                                                data-testid="set-commander-from-pile-@card.CardId"
                                                disabled="@(!card.IsCommanderEligible)"
                                                title="@(card.IsCommanderEligible ? "Set this card as your commander" : "Only legal commanders can be selected.")"
                                                @onclick="() => SetCommanderRequested.InvokeAsync(card.CardId)">
                                            Set as commander
                                        </button>
                                    }

                                    <button type="button"
                                            class="pile-board__remove-button"
                                            data-testid="remove-@card.CardId"
                                            @onclick="() => RemoveRequested.InvokeAsync(card.CardId)">
                                        Remove
                                    </button>
                                </div>
                            </article>
                        }
                    }
                </div>
            </section>
        }
    </div>
</section>

@code {
    [Parameter]
    public required IReadOnlyList<PileDefinitionContract> Piles { get; set; }

    [Parameter]
    public required IReadOnlyList<WorkspaceCardView> Cards { get; set; }

    [Parameter]
    public bool CommanderSelectionEnabled { get; set; }

    [Parameter]
    public EventCallback<string> SetCommanderRequested { get; set; }

    [Parameter]
    public EventCallback<string> RemoveRequested { get; set; }

    private IReadOnlyList<PileDefinitionContract> VisibleLanes => Piles
        .Where(static pile => string.Equals(pile.PileId, DeckWorkspaceViewModel.CommandZonePileId, StringComparison.OrdinalIgnoreCase)
            || string.Equals(pile.PileId, DeckWorkspaceViewModel.MainboardPileId, StringComparison.OrdinalIgnoreCase))
        .OrderBy(static pile => pile.SortOrder)
        .ToArray();

    private WorkspaceCardView[] GetCardsForPile(string pileId) => Cards
        .Where(card => string.Equals(ResolvePileId(card), pileId, StringComparison.OrdinalIgnoreCase))
        .ToArray();

    private static bool IsCommandZone(string pileId) => string.Equals(pileId, DeckWorkspaceViewModel.CommandZonePileId, StringComparison.OrdinalIgnoreCase);

    private static string GetLaneClass(string pileId) => IsCommandZone(pileId)
        ? "pile-board__pile--command"
        : "pile-board__pile--mainboard";

    private static string GetLaneBadge(string pileId) => IsCommandZone(pileId)
        ? "Commander lane"
        : "Mainboard lane";

    private static string GetLaneDescription(string pileId) => IsCommandZone(pileId)
        ? "Reserved for the commander and any paired face or partner card."
        : "The full deck shell lives here so cuts, ratios, and role balance stay easy to scan.";

    private static string GetEmptyMessage(string pileId) => IsCommandZone(pileId)
        ? "Choose a legal commander to activate the command zone."
        : "Search results and imports add cards straight into the mainboard.";

    private static string ResolvePileId(WorkspaceCardView card) => card.IsCommander
        ? DeckWorkspaceViewModel.CommandZonePileId
        : card.AssignedPileId;
}