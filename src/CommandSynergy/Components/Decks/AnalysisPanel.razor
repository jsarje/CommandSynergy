@using CommandSynergy.Application.Contracts

@if (IsLoading)
{
    <div class="analysis-panel analysis-panel--loading" data-testid="analysis-panel-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <p class="analysis-panel__message">Fetching bracket and synergy results…</p>
    </div>
}
else if (HasError)
{
    <div class="analysis-panel analysis-panel--error" data-testid="analysis-panel-error">
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            Analysis is temporarily unavailable. Retry sync to refresh the bracket result.
        </MudAlert>
    </div>
}
else if (Analysis is null)
{
    <div class="analysis-panel analysis-panel--empty" data-testid="analysis-panel-empty">
        <p class="analysis-panel__message">Bracket feedback arrives after the first successful sync.</p>
    </div>
}
else
{
    <div class="analysis-panel analysis-panel--ready" data-testid="analysis-panel-ready">
        <div class="analysis-bracket" data-testid="analysis-bracket">
            <div class="analysis-bracket__header">
                <h4 class="analysis-bracket__label">Bracket @Analysis.Bracket.Level</h4>
                <span class="analysis-bracket__weight"
                      title="Total bracket weight">@Analysis.Bracket.TotalWeight.ToString("0.##")</span>
            </div>
            <p class="analysis-bracket__summary">@Analysis.Bracket.Summary</p>

            @if (Analysis.Bracket.Factors.Count > 0)
            {
                <ul class="analysis-factors" data-testid="bracket-factors">
                    @foreach (var factor in Analysis.Bracket.Factors)
                    {
                        <li class="analysis-factor analysis-factor--@factor.Category">
                            <span class="analysis-factor__weight">+@factor.Weight.ToString("0.##")</span>
                            <span class="analysis-factor__explanation">@factor.Explanation</span>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="analysis-synergy" data-testid="analysis-synergy">
            <div class="analysis-synergy__header">
                <h4 class="analysis-synergy__label">Synergy</h4>
                <span class="analysis-synergy__score"
                      title="Synergy score (0–100)">@Analysis.Synergy.Score.ToString("0.#")</span>
            </div>
            <p class="analysis-synergy__summary">@Analysis.Synergy.Summary</p>

            @if (Analysis.Synergy.CommanderSpecificHits.Count > 0)
            {
                <p class="analysis-synergy__hits-label">Commander-specific hits</p>
                <ul class="analysis-synergy__hits" data-testid="synergy-commander-hits">
                    @foreach (var hit in Analysis.Synergy.CommanderSpecificHits)
                    {
                        <li class="analysis-synergy__hit">@hit</li>
                    }
                </ul>
            }

            @if (Analysis.Synergy.StapleOverloadIndicators.Count > 0)
            {
                <p class="analysis-synergy__staples-label">Staple overload indicators</p>
                <ul class="analysis-synergy__staples" data-testid="synergy-staple-overload">
                    @foreach (var staple in Analysis.Synergy.StapleOverloadIndicators)
                    {
                        <li class="analysis-synergy__staple">@staple</li>
                    }
                </ul>
            }
        </div>
    </div>
}

@code {
    /// <summary>
    /// Gets or sets the current analysis response, or null when no analysis is available yet.
    /// </summary>
    [Parameter]
    public DeckAnalysisResponseContract? Analysis { get; set; }

    /// <summary>
    /// Gets or sets whether an analysis request is currently in progress.
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; }

    /// <summary>
    /// Gets or sets whether the analysis panel is in an error recovery state.
    /// </summary>
    [Parameter]
    public bool HasError { get; set; }
}
