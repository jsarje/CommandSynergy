@using CommandSynergy.Application.Contracts

@if (IsLoading && Analysis is null)
{
    <div class="analysis-panel analysis-panel--loading" data-testid="synergy-analysis-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <p class="analysis-panel__message">Reading synergy…</p>
    </div>
}
else if (HasError)
{
    <div class="analysis-panel analysis-panel--error" data-testid="synergy-analysis-error">
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            Synergy analysis is temporarily unavailable. Retry sync to refresh the current synergy read.
        </MudAlert>
    </div>
}
else if (Analysis is null)
{
    <div class="analysis-panel analysis-panel--empty" data-testid="synergy-analysis-empty">
        <p class="analysis-panel__message">Synergy appears after the first sync.</p>
    </div>
}
else
{
    <section class="analysis-panel analysis-panel--ready analysis-synergy" data-testid="analysis-synergy" aria-busy="@IsLoading">
        <div class="analysis-panel__header">
            <div>
                <h4 class="analysis-synergy__label">Synergy</h4>
                @if (IsLoading)
                {
                    <p class="analysis-panel__refresh-banner" data-testid="synergy-analysis-refreshing" role="status" aria-live="polite">
                        Refreshing. Showing the previous result.
                    </p>
                }
            </div>
            @if (Analysis.ThemeAnalysis?.IsInsufficient == true)
            {
                <span class="analysis-panel__label-pill analysis-panel__label-pill--muted"
                      data-testid="synergy-analysis-pill"
                      title="Synergy score is hidden for undersized decks">Need 20 cards</span>
            }
            else
            {
                <span class="analysis-panel__label-pill analysis-panel__label-pill--synergy"
                      data-testid="synergy-analysis-pill"
                      title="Synergy score (0–100)">
                    @Analysis.Synergy.Label · @((Analysis.Synergy.FinalScore == 0m ? Analysis.Synergy.Score : Analysis.Synergy.FinalScore).ToString("0.#"))
                </span>
            }
        </div>

        <p class="analysis-panel__summary">@Analysis.Synergy.Summary</p>

        @foreach (var section in Analysis.Synergy.SupportingSections)
        {
            <section class="analysis-panel__section" aria-labelledby="@GetSectionId(section.Title)">
                <div class="analysis-panel__section-header">
                    <h5 id="@GetSectionId(section.Title)">@section.Title</h5>
                </div>
                <ul class="analysis-panel__list" data-testid="@GetSectionTestId(section.Title)">
                    @foreach (var item in section.Items)
                    {
                        <li class="analysis-panel__item analysis-panel__item--@item.Tone">
                            <div>
                                <strong>@item.Label</strong>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <p>@item.Description</p>
                                }
                            </div>
                            <span class="analysis-panel__item-value">@item.Value</span>
                        </li>
                    }
                </ul>
            </section>
        }
    </section>
}

@code {
    /// <summary>
    /// Gets or sets the current analysis response, or null when no analysis is available yet.
    /// </summary>
    [Parameter]
    public DeckAnalysisResponseContract? Analysis { get; set; }

    /// <summary>
    /// Gets or sets whether a synergy analysis request is currently in progress.
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; }

    /// <summary>
    /// Gets or sets whether the synergy analysis is in an error recovery state.
    /// </summary>
    [Parameter]
    public bool HasError { get; set; }

    private static string GetSectionId(string title) => $"synergy-analysis-{Slugify(title)}";

    private static string GetSectionTestId(string title) => title switch
    {
        "Commander hits" => "synergy-commander-hits",
        "Cautions" => "synergy-staple-overload",
        _ => $"synergy-analysis-{Slugify(title)}",
    };

    private static string Slugify(string value) => value.ToLowerInvariant().Replace(" ", "-");
}
