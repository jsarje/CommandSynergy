@using CommandSynergy.Application.Contracts

@if (IsLoading && Analysis is null)
{
    <div class="analysis-panel analysis-panel--loading" data-testid="power-analysis-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <p class="analysis-panel__message">Reading power…</p>
    </div>
}
else if (HasError)
{
    <div class="analysis-panel analysis-panel--error" data-testid="power-analysis-error">
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            Power level analysis is temporarily unavailable. Retry sync to refresh the current power read.
        </MudAlert>
    </div>
}
else if (Analysis is null)
{
    <div class="analysis-panel analysis-panel--empty" data-testid="power-analysis-empty">
        <p class="analysis-panel__message">Power appears after the first sync.</p>
    </div>
}
else
{
    <section class="analysis-panel analysis-panel--ready analysis-power" data-testid="analysis-power" aria-busy="@IsLoading">
        <div class="analysis-panel__header">
            <div>
                <h4 class="analysis-power__label">Power Level</h4>
                @if (IsLoading)
                {
                    <p class="analysis-panel__refresh-banner" data-testid="power-analysis-refreshing" role="status" aria-live="polite">
                        Refreshing. Showing the previous result.
                    </p>
                }
            </div>
            <span class="analysis-panel__label-pill analysis-panel__label-pill--power"
                  data-testid="power-analysis-pill"
                  title="Heuristic power level (1–10)">
                @Analysis.PowerLevel.Label · @Analysis.PowerLevel.Score.ToString("0.0")
            </span>
        </div>

        <p class="analysis-panel__summary">@Analysis.PowerLevel.Summary</p>

        @foreach (var section in Analysis.PowerLevel.SupportingSections)
        {
            <section class="analysis-panel__section" aria-labelledby="@GetSectionId(section.Title)">
                <div class="analysis-panel__section-header">
                    <h5 id="@GetSectionId(section.Title)">@section.Title</h5>
                </div>
                <ul class="analysis-panel__list" data-testid="@GetSectionTestId(section.Title)">
                    @foreach (var item in section.Items)
                    {
                        <li class="analysis-panel__item analysis-panel__item--@item.Tone">
                            <div>
                                <strong>@item.Label</strong>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <p>@item.Description</p>
                                }
                            </div>
                            <span class="analysis-panel__item-value">@item.Value</span>
                        </li>
                    }
                </ul>
            </section>
        }
    </section>
}

@code {
    /// <summary>
    /// Gets or sets the current analysis response, or null when no analysis is available yet.
    /// </summary>
    [Parameter]
    public DeckAnalysisResponseContract? Analysis { get; set; }

    /// <summary>
    /// Gets or sets whether a power level analysis request is currently in progress.
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; }

    /// <summary>
    /// Gets or sets whether the power level analysis is in an error recovery state.
    /// </summary>
    [Parameter]
    public bool HasError { get; set; }

    private static string GetSectionId(string title) => $"power-analysis-{Slugify(title)}";

    private static string GetSectionTestId(string title) => $"power-analysis-{Slugify(title)}";

    private static string Slugify(string value) => value.ToLowerInvariant().Replace(" ", "-");
}
