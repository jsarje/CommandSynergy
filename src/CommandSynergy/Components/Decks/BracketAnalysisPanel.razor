@using CommandSynergy.Application.Contracts

@if (IsLoading && Analysis is null)
{
    <div class="analysis-panel analysis-panel--loading" data-testid="bracket-analysis-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <p class="analysis-panel__message">Reading bracket…</p>
    </div>
}
else if (HasError)
{
    <div class="analysis-panel analysis-panel--error" data-testid="bracket-analysis-error">
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            Bracket analysis is temporarily unavailable. Retry sync to refresh the current bracket read.
        </MudAlert>
    </div>
}
else if (Analysis is null)
{
    <div class="analysis-panel analysis-panel--empty" data-testid="bracket-analysis-empty">
        <p class="analysis-panel__message">Bracket appears after the first sync.</p>
    </div>
}
else
{
    <section class="analysis-panel analysis-panel--ready analysis-bracket" data-testid="analysis-bracket" aria-busy="@IsLoading">
        <div class="analysis-panel__header">
            <div>
                <h4 class="analysis-bracket__label">Bracket</h4>
                @if (IsLoading)
                {
                    <p class="analysis-panel__refresh-banner" data-testid="bracket-analysis-refreshing" role="status" aria-live="polite">
                        Refreshing. Showing the previous result.
                    </p>
                }
            </div>
            <span class="analysis-panel__label-pill analysis-panel__label-pill--bracket"
                  data-testid="bracket-analysis-pill"
                  title="Commander bracket read">Bracket @Analysis.Bracket.Level</span>
        </div>

        <p class="analysis-panel__summary">@Analysis.Bracket.Summary</p>

        <section class="analysis-panel__section" aria-labelledby="bracket-overview-title">
            <div class="analysis-panel__section-header">
                <h5 id="bracket-overview-title">Overview</h5>
            </div>
            <ul class="analysis-panel__list" data-testid="bracket-analysis-overview">
                <li class="analysis-panel__item analysis-panel__item--neutral">
                    <div>
                        <strong>Total weight</strong>
                        <p>Accumulated bracket pressure from the current deck signals.</p>
                    </div>
                    <span class="analysis-panel__item-value">@Analysis.Bracket.TotalWeight.ToString("0.##")</span>
                </li>
                <li class="analysis-panel__item analysis-panel__item--neutral">
                    <div>
                        <strong>Top drivers</strong>
                        <p>@(Analysis.Bracket.Factors.Count == 0 ? "No bracket-defining signals surfaced yet." : $"{Analysis.Bracket.Factors.Count} weighted factor(s) are currently shaping the read.")</p>
                    </div>
                    <span class="analysis-panel__item-value">@Analysis.Bracket.Factors.Count</span>
                </li>
            </ul>
        </section>

        <section class="analysis-panel__section" aria-labelledby="bracket-factors-title">
            <div class="analysis-panel__section-header">
                <h5 id="bracket-factors-title">Weighted factors</h5>
            </div>

            @if (Analysis.Bracket.Factors.Count == 0)
            {
                <p class="analysis-panel__message">No bracket-defining signals were detected.</p>
            }
            else
            {
                <ul class="analysis-panel__list analysis-factors" data-testid="bracket-factors">
                    @foreach (var factor in Analysis.Bracket.Factors)
                    {
                        <li class="analysis-panel__item analysis-factor analysis-factor--@factor.Category">
                            <div>
                                <strong>@FormatCategoryLabel(factor.Category)</strong>
                                <p class="analysis-factor__explanation">@factor.Explanation</p>
                            </div>
                            <span class="analysis-panel__item-value analysis-factor__weight">+@factor.Weight.ToString("0.##")</span>
                        </li>
                    }
                </ul>
            }
        </section>
    </section>
}

@code {
    /// <summary>
    /// Gets or sets the current analysis response, or null when no analysis is available yet.
    /// </summary>
    [Parameter]
    public DeckAnalysisResponseContract? Analysis { get; set; }

    /// <summary>
    /// Gets or sets whether a bracket analysis request is currently in progress.
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; }

    /// <summary>
    /// Gets or sets whether the bracket analysis is in an error recovery state.
    /// </summary>
    [Parameter]
    public bool HasError { get; set; }

    private static string FormatCategoryLabel(string category)
    {
        if (string.IsNullOrWhiteSpace(category))
        {
            return "Signal";
        }

        return string.Join(' ', category.Split('-', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(static part => char.ToUpperInvariant(part[0]) + part[1..]));
    }
}
