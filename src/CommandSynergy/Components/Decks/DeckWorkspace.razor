@using CommandSynergy.Application.Contracts
@using CommandSynergy.Application.Decks.Portability

<div class="workspace-shell">
    <MudContainer MaxWidth="MaxWidth.False" Class="workspace-shell__container">
        <MudAppBar Elevation="0" Dense="true" Class="workspace-appbar">
            <div class="workspace-appbar__inner">
                <div class="workspace-appbar__brand">                    
                    <strong class="workspace-appbar__name">Synergy Sphere</strong>
                </div>

                <button type="button"
                        class="workspace-appbar__action"
                        aria-expanded="@isUtilityMenuOpen.ToString().ToLowerInvariant()"
                        aria-controls="workspace-utility-drawer"
                        aria-label="Open Deck Library"
                        @onclick="ToggleUtilityMenu">
                    Deck Library
                </button>
            </div>
        </MudAppBar>

        @if (isUtilityMenuOpen)
        {
            <DeckUtilityPanel ImportedDecks="ImportedDecks"
                              IsHydratingLibrary="IsHydratingLibrary"
                              IsImporting="@isImporting"
                              ActiveImportedDeckId="ActiveImportedDeckId"
                              OpenImportedDeckRequested="OpenImportedDeckRequested"
                              StartNewDeckRequested="StartNewDeckRequested"
                              IsWorkspaceLinkedToSavedDeck="IsWorkspaceLinkedToSavedDeck"
                              ActiveWorkspaceDeckName="ActiveWorkspaceDeckName"
                              LinkedDeckName="LinkedDeckName"
                              LinkedDeckNameChanged="LinkedDeckNameChanged"
                              CanRenameLinkedDeck="CanRenameLinkedDeck"
                              RenameLinkedDeckRequested="RenameLinkedDeckRequested"
                              LinkedDeckStatusMessage="LinkedDeckStatusMessage"
                              LinkedDeckStatusHasError="LinkedDeckStatusHasError"
                              NewDeckName="NewDeckName"
                              NewDeckNameChanged="NewDeckNameChanged"
                              CanSaveNewDeck="CanSaveNewDeck"
                              SaveNewDeckRequested="SaveNewDeckRequested"
                              LibraryRecoveryMessage="LibraryRecoveryMessage"
                              ActiveImportedDeckDiagnostics="ActiveImportedDeckDiagnostics"
                              SupportedImportFormats="SupportedImportFormats"
                              SelectedImportFormatId="SelectedImportFormatId"
                              ImportFormatChanged="ImportFormatChanged"
                              ImportDocumentText="ImportDocumentText"
                              ImportDocumentTextChanged="ImportDocumentTextChanged"
                              ImportRequested="OnImportRequestedAsync"
                              ImportStatusMessage="ImportStatusMessage"
                              HasPendingDuplicateImport="HasPendingDuplicateImport"
                              PendingDuplicateImportName="PendingDuplicateImportName"
                              PendingDuplicateImportTargetName="PendingDuplicateImportTargetName"
                              UpdateExistingImportedDeckRequested="OnUpdateExistingImportAsync"
                              ImportDuplicateAsNewDeckRequested="OnImportDuplicateAsNewAsync"
                              ImportedDeckSelected="ImportedDeckSelected"
                              OpenDeleteImportedDeckRequested="(id) => OpenDeleteImportedDeckDialog(id)"
                              ExportPreview="ExportPreview"
                              SupportedExportFormats="SupportedExportFormats"
                              SelectedExportFormatId="SelectedExportFormatId"
                              ExportStatusMessage="ExportStatusMessage"
                              ExportFormatChanged="ExportFormatChanged"
                              ExportRequested="ExportRequested"
                              CloseRequested="() => CloseUtilityMenu()" />
        }

        @if (isImporting)
        {
            <div style="position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.6);z-index:1000">
                <div style="text-align:center;padding:16px;border-radius:8px;background:rgba(255,255,255,0.9);box-shadow:0 6px 18px rgba(0,0,0,0.08);">
                    <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                    <div style="margin-top:8px;font-weight:600">Importing deck…</div>
                </div>
            </div>
        }

        <section class="workspace-shell__signals">
            <DeckSignalsPanel State="State"
                          Analysis="Analysis"
                          CommanderName="@(ActiveCommander?.Name ?? "Unset")"
                          DeckName="@(ActiveWorkspaceDeckName ?? NewDeckName ?? "Unset")"
                          IsRefreshingInsights="IsRefreshingInsights"
                          IsHydratingLibrary="IsHydratingLibrary"
                          IsAutoOpeningDeck="IsAutoOpeningDeck"
                          RetryRequested="RetryRequested" />
        </section>

        <section class="workspace-shell__search">
            <MudPaper Elevation="0" Class="workspace-panel workspace-panel--search">
                <div class="workspace-panel__header">
                    <div>
                        <p class="workspace-panel__label">Search</p>
                        <h2>Find cards</h2>
                    </div>
                </div>

                <div class="workspace-search workspace-search--compact">
                    <MudTextField T="string"
                                  Placeholder="Search commanders, staples, or role players"
                                  Value="@SearchQuery"
                                  ValueChanged="SearchQueryChanged"
                                  Immediate="true"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Rounded.Search"
                                  Class="workspace-search__field" />
                        <button type="button"
                            class="workspace-search__button"
                            @onclick="SearchRequested"
                            disabled="@(IsBusy || isImporting)">
                        Search
                    </button>
                </div>

                <div class="workspace-search-results" data-testid="search-results">
                    @if (SearchResults.Count == 0)
                    {
                        <p class="workspace-panel__empty">Search for a commander or a card name to start building the list.</p>
                    }
                    else
                    {
                        @foreach (var card in SearchResults)
                        {
                            <article class="workspace-search-result">
                                <CommanderCard Card="card" />
                                <div class="workspace-search-result__actions">
                                    <button type="button"
                                            class="workspace-search-result__primary"
                                            data-testid="@($"set-commander-{card.CardId}")"
                                            disabled="@(isImporting || !card.IsCommanderEligible)"
                                            title="@(card.IsCommanderEligible ? "Set this card as your commander" : "Only legal commanders can be selected.")"
                                            @onclick="() => CommanderSelected.InvokeAsync(card.CardId)">
                                        Set as commander
                                    </button>
                                    <button type="button"
                                            class="workspace-search-result__secondary"
                                            @onclick="() => CardAdded.InvokeAsync(card.CardId)"
                                            disabled="@isImporting">
                                        Add to deck
                                    </button>
                                </div>
                            </article>
                        }
                    }
                </div>
            </MudPaper>
        </section>        

        <PileBoard Piles="Piles"
                   Cards="Cards"
                   CommanderSelectionEnabled="@true"
                   SetCommanderRequested="CommanderSelected"
                   IncrementRequested="CardIncrementRequested"
                   DecrementRequested="CardDecrementRequested"
                   RemoveRequested="CardRemoved" />

        <section class="workspace-shell__stats-panel">
            <MudPaper Elevation="0" Class="workspace-panel workspace-panel--stats">
                <MudExpansionPanels MultiExpansion="true" Outlined="true" Elevation="0" Class="workspace-disclosure-set workspace-disclosure-set--stats">
                    <MudExpansionPanel Text="Deck stats" Expanded="@(Analysis is not null && !IsRefreshingInsights && State.Status != DeckWorkspaceStatus.Recovery)">
                        <DeckStatsPanel Analysis="Analysis" IsLoading="IsRefreshingInsights" HasError="@(State.Status == DeckWorkspaceStatus.Recovery)" />
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudPaper>
        </section>

        @if (pendingDeleteDeck is not null)
        {
            <div class="workspace-dialog-backdrop" data-testid="delete-imported-deck-dialog">
                <section class="workspace-dialog" role="dialog" aria-modal="true" aria-labelledby="delete-imported-deck-title">
                    <div class="workspace-dialog__content">
                        <p class="workspace-panel__label">Confirm delete</p>
                        <h2 id="delete-imported-deck-title">Delete @pendingDeleteDeck.Name?</h2>
                        <p>This removes the imported deck from this browser only. Your open working copy stays available until you replace it.</p>
                    </div>
                    <div class="workspace-dialog__actions">
                        <button type="button"
                                class="workspace-search-result__secondary"
                                data-testid="cancel-delete-imported-deck"
                                disabled="@isDeletingImportedDeck"
                                @onclick="CancelDeleteImportedDeck">
                            Cancel
                        </button>
                        <button type="button"
                                class="workspace-search-result__danger"
                                data-testid="confirm-delete-imported-deck"
                                disabled="@isDeletingImportedDeck"
                                @onclick="ConfirmDeleteImportedDeckAsync">
                            @(isDeletingImportedDeck ? "Deleting..." : "Delete deck")
                        </button>
                    </div>
                </section>
            </div>
        }
    </MudContainer>
</div>

@code {
    [Parameter]
    public required DeckWorkspaceState State { get; set; }

    [Parameter]
    public DeckAnalysisResponseContract? Analysis { get; set; }

    [Parameter]
    public required string SearchQuery { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public bool IsRefreshingInsights { get; set; }

    [Parameter]
    public bool IsHydratingLibrary { get; set; }

    [Parameter]
    public bool IsAutoOpeningDeck { get; set; }

    [Parameter]
    public string? LibraryRecoveryMessage { get; set; }

    [Parameter]
    public required IReadOnlyList<PileDefinitionContract> Piles { get; set; }

    [Parameter]
    public required IReadOnlyList<WorkspaceCardView> Cards { get; set; }

    [Parameter]
    public required IReadOnlyList<WorkspaceCardView> SearchResults { get; set; }

    [Parameter]
    public required IReadOnlyList<FormatOptionView> SupportedImportFormats { get; set; }

    [Parameter]
    public string? SelectedImportFormatId { get; set; }

    [Parameter]
    public required string ImportDocumentText { get; set; }

    [Parameter]
    public required IReadOnlyList<ImportedDeckRecord> ImportedDecks { get; set; }

    [Parameter]
    public string? ActiveImportedDeckId { get; set; }

    [Parameter]
    public bool IsWorkspaceLinkedToSavedDeck { get; set; }

    [Parameter]
    public string? ActiveWorkspaceDeckName { get; set; }

    [Parameter]
    public required string LinkedDeckName { get; set; }

    [Parameter]
    public string? LinkedDeckStatusMessage { get; set; }

    [Parameter]
    public bool LinkedDeckStatusHasError { get; set; }

    [Parameter]
    public required IReadOnlyList<ImportDiagnostic> ActiveImportedDeckDiagnostics { get; set; }

    [Parameter]
    public string? ImportStatusMessage { get; set; }

    [Parameter]
    public required string NewDeckName { get; set; }

    [Parameter]
    public bool CanSaveNewDeck { get; set; }

    [Parameter]
    public bool CanRenameLinkedDeck { get; set; }

    [Parameter]
    public bool HasPendingDuplicateImport { get; set; }

    [Parameter]
    public string? PendingDuplicateImportName { get; set; }

    [Parameter]
    public string? PendingDuplicateImportTargetName { get; set; }

    [Parameter]
    public ExportPreviewContract? ExportPreview { get; set; }

    [Parameter]
    public required IReadOnlyList<FormatOptionView> SupportedExportFormats { get; set; }

    [Parameter]
    public required string SelectedExportFormatId { get; set; }

    [Parameter]
    public string? ExportStatusMessage { get; set; }

    [Parameter]
    public EventCallback<string> SearchQueryChanged { get; set; }

    [Parameter]
    public EventCallback<string> ImportDocumentTextChanged { get; set; }

    [Parameter]
    public EventCallback<string?> ImportFormatChanged { get; set; }

    [Parameter]
    public EventCallback ImportRequested { get; set; }

    [Parameter]
    public EventCallback UpdateExistingImportedDeckRequested { get; set; }

    [Parameter]
    public EventCallback ImportDuplicateAsNewDeckRequested { get; set; }

    [Parameter]
    public EventCallback<string> ImportedDeckSelected { get; set; }

    [Parameter]
    public EventCallback<string> ImportedDeckDeleteRequested { get; set; }

    [Parameter]
    public EventCallback OpenImportedDeckRequested { get; set; }

    [Parameter]
    public EventCallback StartNewDeckRequested { get; set; }

    [Parameter]
    public EventCallback<string> NewDeckNameChanged { get; set; }

    [Parameter]
    public EventCallback SaveNewDeckRequested { get; set; }

    [Parameter]
    public EventCallback<string> LinkedDeckNameChanged { get; set; }

    [Parameter]
    public EventCallback RenameLinkedDeckRequested { get; set; }

    [Parameter]
    public EventCallback<string> ExportFormatChanged { get; set; }

    [Parameter]
    public EventCallback ExportRequested { get; set; }

    [Parameter]
    public EventCallback SearchRequested { get; set; }

    [Parameter]
    public EventCallback RetryRequested { get; set; }

    [Parameter]
    public EventCallback<string> CommanderSelected { get; set; }

    [Parameter]
    public EventCallback<string> CardAdded { get; set; }

    [Parameter]
    public EventCallback<string> CardIncrementRequested { get; set; }

    [Parameter]
    public EventCallback<string> CardDecrementRequested { get; set; }

    [Parameter]
    public EventCallback<MoveCardRequest> CardMoved { get; set; }

    [Parameter]
    public EventCallback<string> CardRemoved { get; set; }

    private ImportedDeckRecord? pendingDeleteDeck;

    private bool isDeletingImportedDeck;

    private bool isUtilityMenuOpen;

    private bool isImporting;

    private WorkspaceCardView? ActiveCommander => Cards.FirstOrDefault(static card => card.IsCommander);

    private int TotalDeckCards => Cards.Sum(static card => card.Quantity);

    protected override void OnParametersSet()
    {
        if (pendingDeleteDeck is not null
            && ImportedDecks.All(deck => !string.Equals(deck.ImportedDeckId, pendingDeleteDeck.ImportedDeckId, StringComparison.OrdinalIgnoreCase)))
        {
            pendingDeleteDeck = null;
            isDeletingImportedDeck = false;
        }
    }

    private void ToggleUtilityMenu()
    {
        isUtilityMenuOpen = !isUtilityMenuOpen;
    }

    private void CloseUtilityMenu()
    {
        isUtilityMenuOpen = false;
    }

    private async Task OnImportRequestedAsync()
    {
        if (isImporting)
            return;

        isImporting = true;
        try
        {
            await ImportRequested.InvokeAsync(null);
        }
        finally
        {
            isImporting = false;
        }
    }

    private async Task OnUpdateExistingImportAsync()
    {
        if (isImporting)
            return;

        isImporting = true;
        try
        {
            await UpdateExistingImportedDeckRequested.InvokeAsync(null);
        }
        finally
        {
            isImporting = false;
        }
    }

    private async Task OnImportDuplicateAsNewAsync()
    {
        if (isImporting)
            return;

        isImporting = true;
        try
        {
            await ImportDuplicateAsNewDeckRequested.InvokeAsync(null);
        }
        finally
        {
            isImporting = false;
        }
    }

    private void OpenDeleteImportedDeckDialog(string importedDeckId)
    {
        pendingDeleteDeck = ImportedDecks.FirstOrDefault(deck => string.Equals(deck.ImportedDeckId, importedDeckId, StringComparison.OrdinalIgnoreCase));
        isUtilityMenuOpen = true;
    }

    private void CancelDeleteImportedDeck()
    {
        pendingDeleteDeck = null;
    }

    private async Task ConfirmDeleteImportedDeckAsync()
    {
        if (pendingDeleteDeck is null)
        {
            return;
        }

        isDeletingImportedDeck = true;

        try
        {
            await ImportedDeckDeleteRequested.InvokeAsync(pendingDeleteDeck.ImportedDeckId);
            pendingDeleteDeck = null;
        }
        finally
        {
            isDeletingImportedDeck = false;
        }
    }
}
