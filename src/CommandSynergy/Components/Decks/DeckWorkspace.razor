@using CommandSynergy.Application.Contracts
@using CommandSynergy.Application.Decks.Portability

<div class="workspace-shell">
    <MudContainer MaxWidth="MaxWidth.False" Class="workspace-shell__container">
        <section class="workspace-shell__hero">
            <p class="workspace-shell__eyebrow">Commander Synergy Sphere</p>
            <h1>Build with tempo, inspect every face, and keep the rules engine in the loop.</h1>
            <p class="workspace-shell__lede">
                Import plaintext decklists locally, switch between saved decks, open an explicit working copy, and export the current workspace without sending raw deck documents to the server.
            </p>
        </section>

        <section class="workspace-shell__summary-grid">
            <MudPaper Elevation="0" Class="workspace-panel workspace-panel--search">
                <div class="workspace-panel__header">
                    <div>
                        <p class="workspace-panel__label">Import</p>
                        <h2>Local deck library</h2>
                    </div>
                    @if (IsHydratingLibrary)
                    {
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    }
                </div>

                <MudSelect T="string" Label="Source format" Value="@SelectedImportFormatId" ValueChanged="ImportFormatChanged">
                    @foreach (var option in SupportedImportFormats)
                    {
                        <MudSelectItem Value="@option.Value">@option.Label</MudSelectItem>
                    }
                </MudSelect>

                <MudTextField T="string"
                              Label="Paste deck text"
                              Lines="10"
                              Value="@ImportDocumentText"
                              ValueChanged="ImportDocumentTextChanged"
                              Variant="Variant.Outlined" />

                <div class="workspace-search">
                    <button type="button" class="workspace-search__button" @onclick="ImportRequested">Import deck</button>
                    <button type="button" class="workspace-search__button" @onclick="OpenImportedDeckRequested" disabled="@string.IsNullOrWhiteSpace(ActiveImportedDeckId)">Open working copy</button>
                    <button type="button" class="workspace-search__button" @onclick="StartNewDeckRequested">New deck</button>
                </div>

                @if (IsWorkspaceLinkedToSavedDeck)
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" data-testid="workspace-link-status">
                        Editing <strong>@ActiveWorkspaceDeckName</strong>. Changes in this working copy persist automatically to the selected saved deck.
                    </MudAlert>

                    <div class="workspace-search" data-testid="linked-deck-rename-controls">
                        <MudTextField T="string"
                                      Label="Saved deck name"
                                      Value="@LinkedDeckName"
                                      ValueChanged="LinkedDeckNameChanged"
                                      Variant="Variant.Outlined" />
                        <button type="button"
                                class="workspace-search__button"
                                @onclick="RenameLinkedDeckRequested"
                                disabled="@(!CanRenameLinkedDeck)">
                            Rename saved deck
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(LinkedDeckStatusMessage))
                    {
                        <MudAlert Severity="@(LinkedDeckStatusHasError ? Severity.Warning : Severity.Success)"
                                  Variant="Variant.Outlined"
                                  data-testid="linked-deck-rename-status">
                            @LinkedDeckStatusMessage
                        </MudAlert>
                    }
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" data-testid="workspace-link-status">
                        This workspace is detached from the local library. Save it when you want a new deck entry that reopens with its latest changes.
                    </MudAlert>

                    <div class="workspace-search" data-testid="new-deck-save-controls">
                        <MudTextField T="string"
                                      Label="New deck name"
                                      Value="@NewDeckName"
                                      ValueChanged="NewDeckNameChanged"
                                      Variant="Variant.Outlined" />
                        <button type="button"
                                class="workspace-search__button"
                                @onclick="SaveNewDeckRequested"
                                disabled="@(!CanSaveNewDeck)">
                            Save to library
                        </button>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(LibraryRecoveryMessage))
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">@LibraryRecoveryMessage</MudAlert>
                }

                @if (!string.IsNullOrWhiteSpace(ImportStatusMessage))
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@ImportStatusMessage</MudAlert>
                }

                @if (HasPendingDuplicateImport)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" data-testid="duplicate-import-resolution">
                        <div class="workspace-callouts">
                            <div>
                                <h3>Reimport options</h3>
                                <p>Update the existing <strong>@PendingDuplicateImportName</strong> entry or keep both by saving the new import as <strong>@PendingDuplicateImportTargetName</strong>.</p>
                            </div>
                        </div>
                        <div class="workspace-search">
                            <button type="button" class="workspace-search__button" @onclick="UpdateExistingImportedDeckRequested">Update existing deck</button>
                            <button type="button" class="workspace-search__button" @onclick="ImportDuplicateAsNewDeckRequested">Import as new deck</button>
                        </div>
                    </MudAlert>
                }

                <div class="workspace-search-results" data-testid="imported-deck-library">
                    @if (ImportedDecks.Count == 0)
                    {
                        <p class="workspace-panel__empty">Imported decks stay in this browser only. Paste a supported decklist to start a local library.</p>
                    }
                    else
                    {
                        @foreach (var importedDeck in ImportedDecks)
                        {
                            var isActiveDeck = string.Equals(importedDeck.ImportedDeckId, ActiveImportedDeckId, StringComparison.OrdinalIgnoreCase);
                            <article class="workspace-search-result">
                                <div>
                                    <strong>@importedDeck.Name</strong>
                                    <p>@importedDeck.SourceFormatId</p>
                                </div>
                                <div class="workspace-search-result__actions">
                                    <button type="button"
                                            class="workspace-search-result__primary"
                                            data-testid="@($"select-imported-deck-{importedDeck.ImportedDeckId}")"
                                            @onclick="() => ImportedDeckSelected.InvokeAsync(importedDeck.ImportedDeckId)">
                                        @(isActiveDeck ? "Selected" : "Select")
                                    </button>
                                    <button type="button"
                                            class="workspace-search-result__danger"
                                            data-testid="@($"delete-imported-deck-{importedDeck.ImportedDeckId}")"
                                            @onclick="() => OpenDeleteImportedDeckDialog(importedDeck.ImportedDeckId)">
                                        Delete
                                    </button>
                                </div>
                            </article>
                        }
                    }
                </div>

                @if (ActiveImportedDeckDiagnostics.Count > 0)
                {
                    <div class="workspace-callouts">
                        <div>
                            <h3>Import diagnostics</h3>
                            <ul class="workspace-findings" data-testid="import-diagnostics">
                                @foreach (var diagnostic in ActiveImportedDeckDiagnostics)
                                {
                                    <li class="workspace-finding workspace-finding--@diagnostic.Severity.ToString().ToLowerInvariant()">@diagnostic.Message</li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </MudPaper>

            <DeckExportPanel ExportPreview="@ExportPreview"
                             SupportedFormats="@SupportedExportFormats"
                             SelectedFormatId="@SelectedExportFormatId"
                             ExportStatusMessage="@ExportStatusMessage"
                             ExportFormatChanged="@ExportFormatChanged"
                             ExportRequested="@ExportRequested" />
        </section>

        <section class="workspace-shell__summary-grid">
            <MudPaper Elevation="0" Class="workspace-panel workspace-panel--search">
                <div class="workspace-panel__header">
                    <div>
                        <p class="workspace-panel__label">Search</p>
                        <h2>Draft the shell</h2>
                    </div>
                    @if (IsBusy)
                    {
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    }
                </div>

                <div class="workspace-search">
                    <input class="workspace-search__input"
                           placeholder="Search cards, commanders, or staples"
                           value="@SearchQuery"
                           @oninput="HandleSearchQueryInput" />
                    <button type="button"
                            class="workspace-search__button"
                            @onclick="SearchRequested"
                            disabled="@IsBusy">
                        Search index
                    </button>
                </div>

                <div class="workspace-search-results" data-testid="search-results">
                    @if (SearchResults.Count == 0)
                    {
                        <p class="workspace-panel__empty">Search results land here with quick actions for commander selection and pile staging.</p>
                    }
                    else
                    {
                        @foreach (var card in SearchResults)
                        {
                            <article class="workspace-search-result">
                                <CommanderCard Card="card" />
                                <div class="workspace-search-result__actions">
                                    <button type="button"
                                            class="workspace-search-result__primary"
                                            data-testid="@($"set-commander-{card.CardId}")"
                                            disabled="@(!card.IsCommanderEligible)"
                                            title="@(card.IsCommanderEligible ? "Set this card as your commander" : "Only legal commanders can be selected.")"
                                            @onclick="() => CommanderSelected.InvokeAsync(card.CardId)">
                                        Set as commander
                                    </button>
                                    <button type="button"
                                            class="workspace-search-result__secondary"
                                            @onclick="() => CardAdded.InvokeAsync(card.CardId)">
                                        Add to deck
                                    </button>
                                </div>
                            </article>
                        }
                    }
                </div>
            </MudPaper>

            <MudPaper Elevation="0" Class="workspace-panel workspace-panel--status">
                <div class="workspace-panel__header">
                    <div>
                        <p class="workspace-panel__label">Signals</p>
                        <h2>Validation and bracket pulse</h2>
                    </div>
                </div>

                @if (State.Status == DeckWorkspaceStatus.Loading)
                {
                    <div class="workspace-state workspace-state--loading" data-testid="workspace-loading">
                        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                        <p>Loading workspace shell and deck telemetry.</p>
                    </div>
                }
                else if (State.Status == DeckWorkspaceStatus.Empty)
                {
                    <div class="workspace-state workspace-state--empty" data-testid="workspace-empty">
                        <h3>Commander needed</h3>
                        <p>@State.Message</p>
                    </div>
                }
                else if (State.Status == DeckWorkspaceStatus.Recovery)
                {
                    <div class="workspace-state workspace-state--recovery" data-testid="workspace-recovery">
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                            @State.Message
                        </MudAlert>
                        <button type="button" class="workspace-state__retry" @onclick="RetryRequested">Retry sync</button>
                    </div>
                }
                else
                {
                    <div class="workspace-state workspace-state--ready" data-testid="workspace-ready">
                        <div class="workspace-metric-strip">
                            <div>
                                <span>Deck cards</span>
                                <strong>@State.Validation?.DeckCardCount</strong>
                            </div>
                            <div>
                                <span>Legality</span>
                                <strong>@(State.Validation?.IsValid == true ? "Ready" : "Needs work")</strong>
                            </div>
                            <div>
                                <span>Bracket</span>
                                <strong>@(Analysis?.Bracket.Level.ToString() ?? "-")</strong>
                            </div>
                            <div>
                                <span>Synergy</span>
                                <strong>@(Analysis?.Synergy.Score.ToString("0.#") ?? "-")</strong>
                            </div>
                        </div>

                        <div class="workspace-callouts">
                            <div>
                                <h3>Validation findings</h3>
                                @if (State.Findings.Count == 0)
                                {
                                    <p class="workspace-panel__empty">No findings yet. Add a commander and supporting cards to trigger the rules engine.</p>
                                }
                                else
                                {
                                    <ul class="workspace-findings" data-testid="validation-findings">
                                        @foreach (var finding in State.Findings)
                                        {
                                            <li class="workspace-finding workspace-finding--@finding.Severity">@finding.Message</li>
                                        }
                                    </ul>
                                }
                            </div>

                            <div class="workspace-analysis" data-testid="analysis-panel">
                                <h3>Analysis summary</h3>
                                <AnalysisPanel Analysis="Analysis" IsLoading="IsBusy" HasError="@(State.Status == DeckWorkspaceStatus.Recovery)" />
                            </div>
                        </div>
                    </div>
                }
            </MudPaper>
        </section>

        @if (State.Status == DeckWorkspaceStatus.Empty && Cards.Count > 0)
        {
            <section class="workspace-banner workspace-banner--commander-needed" data-testid="commander-needed-banner">
                <div>
                    <p class="workspace-panel__label">Commander needed</p>
                    <h2>Keep sorting now, choose the commander when you are ready.</h2>
                    <p>Validation and synergy stay paused until you pick a legal commander from search results or use <strong>Set as commander</strong> on an eligible card already in the deck.</p>
                </div>
            </section>
        }

        <PileBoard Piles="Piles"
                   Cards="Cards"
                   CommanderSelectionEnabled="@true"
                   SetCommanderRequested="CommanderSelected"
                   MoveRequested="CardMoved"
                   RemoveRequested="CardRemoved" />

        @if (pendingDeleteDeck is not null)
        {
            <div class="workspace-dialog-backdrop" data-testid="delete-imported-deck-dialog">
                <section class="workspace-dialog" role="dialog" aria-modal="true" aria-labelledby="delete-imported-deck-title">
                    <div class="workspace-dialog__content">
                        <p class="workspace-panel__label">Confirm delete</p>
                        <h2 id="delete-imported-deck-title">Delete @pendingDeleteDeck.Name?</h2>
                        <p>This removes the imported deck from this browser only. Your open working copy stays available until you replace it.</p>
                    </div>
                    <div class="workspace-dialog__actions">
                        <button type="button"
                                class="workspace-search-result__secondary"
                                data-testid="cancel-delete-imported-deck"
                                disabled="@isDeletingImportedDeck"
                                @onclick="CancelDeleteImportedDeck">
                            Cancel
                        </button>
                        <button type="button"
                                class="workspace-search-result__danger"
                                data-testid="confirm-delete-imported-deck"
                                disabled="@isDeletingImportedDeck"
                                @onclick="ConfirmDeleteImportedDeckAsync">
                            @(isDeletingImportedDeck ? "Deleting..." : "Delete deck")
                        </button>
                    </div>
                </section>
            </div>
        }
    </MudContainer>
</div>

@code {
    [Parameter]
    public required DeckWorkspaceState State { get; set; }

    [Parameter]
    public DeckAnalysisResponseContract? Analysis { get; set; }

    [Parameter]
    public required string SearchQuery { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public bool IsHydratingLibrary { get; set; }

    [Parameter]
    public string? LibraryRecoveryMessage { get; set; }

    [Parameter]
    public required IReadOnlyList<PileDefinitionContract> Piles { get; set; }

    [Parameter]
    public required IReadOnlyList<WorkspaceCardView> Cards { get; set; }

    [Parameter]
    public required IReadOnlyList<WorkspaceCardView> SearchResults { get; set; }

    [Parameter]
    public required IReadOnlyList<FormatOptionView> SupportedImportFormats { get; set; }

    [Parameter]
    public string? SelectedImportFormatId { get; set; }

    [Parameter]
    public required string ImportDocumentText { get; set; }

    [Parameter]
    public required IReadOnlyList<ImportedDeckRecord> ImportedDecks { get; set; }

    [Parameter]
    public string? ActiveImportedDeckId { get; set; }

    [Parameter]
    public bool IsWorkspaceLinkedToSavedDeck { get; set; }

    [Parameter]
    public string? ActiveWorkspaceDeckName { get; set; }

    [Parameter]
    public required string LinkedDeckName { get; set; }

    [Parameter]
    public string? LinkedDeckStatusMessage { get; set; }

    [Parameter]
    public bool LinkedDeckStatusHasError { get; set; }

    [Parameter]
    public required IReadOnlyList<ImportDiagnostic> ActiveImportedDeckDiagnostics { get; set; }

    [Parameter]
    public string? ImportStatusMessage { get; set; }

    [Parameter]
    public required string NewDeckName { get; set; }

    [Parameter]
    public bool CanSaveNewDeck { get; set; }

    [Parameter]
    public bool CanRenameLinkedDeck { get; set; }

    [Parameter]
    public bool HasPendingDuplicateImport { get; set; }

    [Parameter]
    public string? PendingDuplicateImportName { get; set; }

    [Parameter]
    public string? PendingDuplicateImportTargetName { get; set; }

    [Parameter]
    public ExportPreviewContract? ExportPreview { get; set; }

    [Parameter]
    public required IReadOnlyList<FormatOptionView> SupportedExportFormats { get; set; }

    [Parameter]
    public required string SelectedExportFormatId { get; set; }

    [Parameter]
    public string? ExportStatusMessage { get; set; }

    [Parameter]
    public EventCallback<string> SearchQueryChanged { get; set; }

    [Parameter]
    public EventCallback<string> ImportDocumentTextChanged { get; set; }

    [Parameter]
    public EventCallback<string?> ImportFormatChanged { get; set; }

    [Parameter]
    public EventCallback ImportRequested { get; set; }

    [Parameter]
    public EventCallback UpdateExistingImportedDeckRequested { get; set; }

    [Parameter]
    public EventCallback ImportDuplicateAsNewDeckRequested { get; set; }

    [Parameter]
    public EventCallback<string> ImportedDeckSelected { get; set; }

    [Parameter]
    public EventCallback<string> ImportedDeckDeleteRequested { get; set; }

    [Parameter]
    public EventCallback OpenImportedDeckRequested { get; set; }

    [Parameter]
    public EventCallback StartNewDeckRequested { get; set; }

    [Parameter]
    public EventCallback<string> NewDeckNameChanged { get; set; }

    [Parameter]
    public EventCallback SaveNewDeckRequested { get; set; }

    [Parameter]
    public EventCallback<string> LinkedDeckNameChanged { get; set; }

    [Parameter]
    public EventCallback RenameLinkedDeckRequested { get; set; }

    [Parameter]
    public EventCallback<string> ExportFormatChanged { get; set; }

    [Parameter]
    public EventCallback ExportRequested { get; set; }

    [Parameter]
    public EventCallback SearchRequested { get; set; }

    [Parameter]
    public EventCallback RetryRequested { get; set; }

    [Parameter]
    public EventCallback<string> CommanderSelected { get; set; }

    [Parameter]
    public EventCallback<string> CardAdded { get; set; }

    [Parameter]
    public EventCallback<MoveCardRequest> CardMoved { get; set; }

    [Parameter]
    public EventCallback<string> CardRemoved { get; set; }

    private ImportedDeckRecord? pendingDeleteDeck;

    private bool isDeletingImportedDeck;

    protected override void OnParametersSet()
    {
        if (pendingDeleteDeck is not null
            && ImportedDecks.All(deck => !string.Equals(deck.ImportedDeckId, pendingDeleteDeck.ImportedDeckId, StringComparison.OrdinalIgnoreCase)))
        {
            pendingDeleteDeck = null;
            isDeletingImportedDeck = false;
        }
    }

    private Task HandleSearchQueryInput(ChangeEventArgs args) => SearchQueryChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private void OpenDeleteImportedDeckDialog(string importedDeckId)
    {
        pendingDeleteDeck = ImportedDecks.FirstOrDefault(deck => string.Equals(deck.ImportedDeckId, importedDeckId, StringComparison.OrdinalIgnoreCase));
    }

    private void CancelDeleteImportedDeck()
    {
        pendingDeleteDeck = null;
    }

    private async Task ConfirmDeleteImportedDeckAsync()
    {
        if (pendingDeleteDeck is null)
        {
            return;
        }

        isDeletingImportedDeck = true;

        try
        {
            await ImportedDeckDeleteRequested.InvokeAsync(pendingDeleteDeck.ImportedDeckId);
            pendingDeleteDeck = null;
        }
        finally
        {
            isDeletingImportedDeck = false;
        }
    }
}